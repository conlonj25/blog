---
import "../styles/fonts.css";
import "../styles/global.css";

export interface Props {
  title: string;
  publishDate: string;
  skills: string;
  description: string;
  imageLink: string;
  codeLink: string;
  liveLink: string;
}

const {
  title,
  publishDate,
  skills,
  description,
  imageLink,
  codeLink,
  liveLink,
} = Astro.props;
---

<style>
  div {
    display: flex;
    justify-content: space-around;
  }

  .buttonContainer {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
  }

  img {
    width: 250px;
    width: 150px;
  }

  button {
    border: none;
    border-radius: 0.5rem;
    color: black;
    padding: 15px 32px;
    text-align: center;
    text-decoration: none;
    display: inline-block;
    font-size: 16px;
  }

  .button-code {
    background-color: #23548e;
  }

  .button-live {
    background-color: #23548e;
  }

  p {
    color: dimgrey;
  }
</style>

<div>
  <img src="/assets/logo.webp" />
  <div class="buttonContainer">
    {
      codeLink && (
        <a href={codeLink}>
          <button class="button-code">Code</button>
        </a>
      )
    }
    {
      liveLink && (
        <a href={liveLink}>
          <button class="button-live">Live</button>
        </a>
      )
    }
  </div>
</div>
<p>{skills}</p>
